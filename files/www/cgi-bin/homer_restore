#!/usr/bin/lua
-- CGI: receive Homer zip upload and restore to /www/homer
-- ImmortalWrt compatible: luci.http.getfile() unavailable, use CGI instead

local function die(msg, status)
    status = status or 500
    local text = "Internal Server Error"
    if status == 400 then text = "Bad Request"
    elseif status == 405 then text = "Method Not Allowed" end
    print("Status: " .. status .. " " .. text)
    print("Content-Type: text/html\n")
    print("<h1>Error</h1><p>" .. msg .. "</p>")
    print('<p><a href="/cgi-bin/luci/admin/services/homer">Go back</a></p>')
    os.exit(1)
end

-- Only POST
local method = os.getenv("REQUEST_METHOD") or "GET"
if method ~= "POST" then
    die("Only POST allowed", 405)
end

-- Read boundary from CONTENT_TYPE
local ct = os.getenv("CONTENT_TYPE") or ""
local boundary = ct:match("boundary=(.+)")
if not boundary or boundary == "" then
    die("Missing boundary in Content-Type", 400)
end

-- Read CONTENT_LENGTH
local cl = tonumber(os.getenv("CONTENT_LENGTH") or "0")
if cl <= 0 then
    die("Empty request body (CONTENT_LENGTH=0)", 400)
end

-- Read entire body from stdin
local body = io.stdin:read(cl)
if not body or #body == 0 then
    die("Failed to read request body from stdin", 500)
end

-- Parse multipart/form-data, extract file content
local function parse_multipart(body, boundary)
    -- Body parts are separated by "--" .. boundary
    -- First part starts with "--" .. boundary .. "\r\n"
    -- Last part ends with "--" .. boundary .. "--\r\n"
    local sep = "--" .. boundary
    local pos = 1

    while pos <= #body do
        -- Find next boundary
        local s, e = body:find(sep, pos, true)
        if not s then break end

        -- Check if this is the final boundary (ends with "--")
        local after = body:sub(e + 1, e + 2)
        if after == "--" then
            break -- final boundary, done
        end

        -- After boundary should be "\r\n", then headers
        if body:sub(e + 1, e + 2) ~= "\r\n" then
            pos = e + 1
            break
        end

        local hdr_start = e + 3
        local hdr_end = body:find("\r\n\r\n", hdr_start, true)
        if not hdr_end then break end

        local headers = body:sub(hdr_start, hdr_end - 1)

        -- Find next boundary (start of next part or end)
        local next_s, next_e = body:find("\r\n" .. sep, hdr_end + 4, true)
        local content
        if next_s then
            content = body:sub(hdr_end + 4, next_s - 1)
        else
            -- Try finding final boundary
            local final_s, final_e = body:find("\r\n" .. sep .. "--", hdr_end + 4, true)
            if final_s then
                content = body:sub(hdr_end + 4, final_s - 1)
            else
                -- No next boundary found, read to end
                content = body:sub(hdr_end + 4)
            end
        end

        -- Strip trailing \r\n from content
        if content and #content >= 2 and content:sub(-2) == "\r\n" then
            content = content:sub(1, -3)
        end

        -- Check if this part has a file
        local filename = headers:match('filename="(.-)"')
        if filename and filename ~= "" then
            return content, filename
        end

        pos = (next_s or final_s) and (next_s or final_s) + 1 or (s + 1)
    end

    return nil
end

local file_data, filename = parse_multipart(body, boundary)
if not file_data then
    die("No file found in upload (check form field name)", 400)
end

-- Save to temp file
local tmp_zip = "/tmp/homer_restore.zip"
local f = io.open(tmp_zip, "wb")
if not f then die("Cannot create temp file: " .. tmp_zip, 500) end
f:write(file_data)
f:close()

-- Verify it's a valid zip
local ret_ok, ret_reason, ret_code = os.execute('7z t "' .. tmp_zip .. '" >/dev/null 2>&1')
local valid = (ret_ok == "exit" and ret_code == 0)
if not valid then
    os.remove(tmp_zip)
    die("Uploaded file is not a valid zip archive", 400)
end

-- Backup current /www/homer
os.execute('rm -rf /www/homer_bak 2>/dev/null')
os.execute('[ -d /www/homer ] && mv /www/homer /www/homer_bak')

-- Extract
os.execute('mkdir -p /www/homer')
ret_ok, ret_reason, ret_code = os.execute('cd /www/homer && 7z x "' .. tmp_zip .. '" -y >/dev/null 2>&1')
local extract_ok = (ret_ok == "exit" and ret_code == 0)

if not extract_ok then
    -- Rollback
    os.execute('rm -rf /www/homer')
    os.execute('[ -d /www/homer_bak ] && mv /www/homer_bak /www/homer')
    os.remove(tmp_zip)
    die("Failed to extract zip archive", 500)
end

-- Success
os.remove(tmp_zip)
os.execute('rm -rf /www/homer_bak 2>/dev/null')
os.execute('chmod -R 755 /www/homer')

-- Redirect back to LuCI Homer page
print("Status: 302 Found")
print("Location: /cgi-bin/luci/admin/services/homer")
print("Content-Type: text/html\n")
print([[<html><head><meta http-equiv="refresh" content="0;url=/cgi-bin/luci/admin/services/homer"></head><body><script>window.location="/cgi-bin/luci/admin/services/homer"</script></body></html>]])
